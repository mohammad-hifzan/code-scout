#!/usr/bin/env ruby

require_relative "../lib/scanner"
require "pp"

require_relative "../lib/project_mapper"
require_relative "../lib/inspector"
require_relative "../lib/reference_finder"
require_relative "../lib/route_mapper"
require_relative "../lib/context_builder"
require_relative "../lib/file_loader"
require_relative "../lib/controller_analyzer"
require_relative "../lib/model_analyzer"
require_relative "../lib/graph_builder"

project_path = ARGV[2]
command = ARGV[0]

case command
when "inspect"
  resource_name = ARGV[1]

  project_map = ProjectMapper.new(project_path).map

  pp Inspector.new(project_map, project_path).inspect_model(resource_name)
when "references"
  constant_name = ARGV[1]

  pp ReferenceFinder.new(project_path).find(constant_name)
when "routes"
  project_path = ARGV[1]
  pp RouteMapper.new(project_path).map
when "context"
  resource_name = ARGV[1]

  project_map =
    ProjectMapper.new(project_path).map

  pp ContextBuilder
     .new(project_map, project_path)
     .build(resource_name)
when "controller"
  controller_path = ARGV[1]

  pp ControllerAnalyzer.new.analyze(controller_path)
when "context-files"
  resource_name = ARGV[1]

  project_map =
    ProjectMapper.new(project_path).map

  context =
    ContextBuilder
      .new(project_map, project_path)
      .build(resource_name)

  pp FileLoader
      .new
      .load_context(context)
when "model"
  model_path = ARGV[1]

  pp ModelAnalyzer.new.analyze(model_path)
when "graph"
  model_name = ARGV[1]

  project_map = ProjectMapper.new(project_path).map

  pp GraphBuilder
    .new(project_map)
    .build(model_name)
else
  puts "Unknown command"
end
# project_path = ARGV[0]

# abort("Please provide project path") unless project_path

# scanner = Scanner.new(project_path)

# pp scanner.scan
