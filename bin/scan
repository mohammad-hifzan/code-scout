#!/usr/bin/env ruby

require_relative "../lib/scanner"
require "pp"

require_relative "../lib/project_mapper"
require_relative "../lib/project_index"
require_relative "../lib/inspector"
require_relative "../lib/reference_finder"
require_relative "../lib/route_mapper"
require_relative "../lib/context_builder"
require_relative "../lib/file_loader"
require_relative "../lib/controller_analyzer"
require_relative "../lib/model_analyzer"
require_relative "../lib/graph_builder"
require_relative "../lib/impact_analyzer"
require_relative "../lib/dead_code_finder"
require_relative "../lib/inheritance_usage_finder"
require_relative "../lib/view_analyzer"
require_relative "../lib/dependency_analyzer"
require_relative "../lib/context_engine"
require_relative "../lib/context_ranker"
require_relative "../lib/token_estimator"
require_relative "../lib/context_pruner"

require_relative "../lib/context_rules/base_rule"
require_relative "../lib/context_rules/edit_model_rule"
require_relative "../lib/context_rules/explain_rule"
require_relative "../lib/context_rules/debug_rule"

command      = ARGV.first
rule_name    = ARGV[1]
entity        = ARGV[2]
project_path = ARGV.last

def build_rule(name)
  case name
  when "edit"
    ContextRules::EditModelRule.new
  when "explain"
    ContextRules::ExplainRule.new
  when "debug"
    ContextRules::DebugRule.new
  else
    abort("Unknown rule: #{name}")
  end
end

case command

when "inspect"
  project_map = ProjectMapper.new(project_path).map
  pp Inspector.new(project_map, project_path).inspect_model(entity)

when "references"
  pp ReferenceFinder.new(project_path).find(entity)

when "routes"
  pp RouteMapper.new(project_path).map

when "context"
  project_map = ProjectMapper.new(project_path).map
  pp ContextBuilder.new(project_map, project_path).build(entity)

when "controller"
  project_map = ProjectMapper.new(project_path).map
  controller = project_map[:controllers][entity]

  abort("Unknown controller: #{entity}") unless controller

  pp ControllerAnalyzer.new.analyze(controller[:path])

when "model"
  project_map = ProjectMapper.new(project_path).map
  model = project_map[:models][entity]

  abort("Unknown model: #{entity}") unless model

  pp ModelAnalyzer.new.analyze(model[:path])

when "graph"
  project_map = ProjectMapper.new(project_path).map
  pp GraphBuilder.new(project_map).build(entity)

when "impact"
  project_map = ProjectMapper.new(project_path).map
  analyzer = ImpactAnalyzer.new(project_map, project_path)

  pp analyzer.analyze(entity)

when "dependency"
  project_map = ProjectMapper.new(project_path).map

  analyzer = DependencyAnalyzer.new(
    project_map,
    project_path
  )

  pp analyzer.analyze(entity)

when "deadcode"
  project_map = ProjectMapper.new(project_path).map

  pp DeadCodeFinder
       .new(project_map, project_path)
       .find

when "inheritance"
  project_map = ProjectMapper.new(project_path).map

  pp InheritanceUsageFinder
       .new(project_path, project_map)
       .used_classes

when "view"
  pp ViewAnalyzer.new.analyze(entity)

when "context-engine"
  rule = build_rule(rule_name)

  project_map = ProjectMapper.new(project_path).map
  index = ProjectIndex.new(project_map, project_path)

  pp ContextEngine
       .new(index)
       .build(entity, rule: rule)

when "context-rank"
  rule = build_rule(rule_name)

  project_map = ProjectMapper.new(project_path).map
  index = ProjectIndex.new(project_map, project_path)

  context = ContextEngine
              .new(index)
              .build(entity, rule: rule)

  pp context[:ranked]

when "context-files"
  rule = build_rule(rule_name)

  project_map = ProjectMapper.new(project_path).map
  index = ProjectIndex.new(project_map, project_path)

  context = ContextEngine
              .new(index)
              .build(entity, rule: rule)

  estimated =
    TokenEstimator
      .new
      .estimate(context[:ranked])

  pruned =
    ContextPruner
      .new
      .prune(
        estimated,
        max_tokens: 3000
      )

  pp FileLoader
       .new
       .load_files(pruned[:files])

else
  puts "Unknown command"
end